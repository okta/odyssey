{
  "name": "@okta/unified-ui-shell",
  "version": "0.0.0-development",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:clean": "rimraf dist",
    "build:clean:tempTypes": "rimraf dist/.temp-types dist/tsconfig.production.project.tsbuildinfo",
    "build:source": "yarn vite build",
    "build:i18n:ts": "odyssey-cli i18n build:ts",
    "build:types": "yarn build:clean:tempTypes && tsc --project tsconfig.production.project.json && api-extractor run --local && yarn build:clean:tempTypes",
    "build": "yarn build:clean && yarn build:i18n:ts && yarn build:source && yarn build:types",
    "dev:build-source": "yarn build:source --watch",
    "dev:build-types": "nodemon --watch src --ext ts,tsx --exec \"yarn build:types\"",
    "dev": "yarn concurrently npm:dev:build-source npm:dev:build-types",
    "generate:i18n": "odyssey-cli i18n generate",
    "generate:i18n:pseudoLocaleProperties": "odyssey-cli i18n generate:pseudoLocaleProperties",
    "playwright-install": "yarn playwright install --with-deps chromium",
    "provision": "yarn ok-ui stack-provision",
    "test": "NODE_ENV=test vitest run --reporter=default",
    "typecheck": "tsc --project src/tsconfig.json"
  },
  "peerDependencies": {
    "@okta/odyssey-react-mui": "^1.62.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.53.3",
    "@okta/odyssey-cli": "workspace:*",
    "@okta/odyssey-contributions-ui-component-identifier": "workspace:*",
    "@okta/odyssey-react-mui": "1.62.1",
    "@okta/ok-ui": "^4.16.0",
    "@okta/ui-stacks-component-libraries-odyssey-contributions": "workspace:*",
    "@testing-library/dom": "^10.4",
    "@testing-library/jest-dom": "^6.8",
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "14.x",
    "@types/react": "18.x",
    "@types/react-dom": "18.x",
    "@vitejs/plugin-react": "^5.0",
    "@vitest/browser": "^3.2",
    "@vitest/coverage-v8": "^3.2",
    "@vitest/ui": "^3.2",
    "concurrently": "^9.2.1",
    "jest-axe": "^10.0",
    "jsdom": "^26.1",
    "msw": "^2.10.5",
    "nodemon": "^3.1.14",
    "playwright": "^1.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1",
    "vite-plugin-svgr": "^4.5",
    "vitest": "^3.2"
  }
}
