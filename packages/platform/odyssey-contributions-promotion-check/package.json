{
  "name": "@okta/odyssey-contributions-promotion-check",
  "author": "Okta, Inc.",
  "license": "Apache-2.0",
  "version": "0.0.0-development",
  "description": "Monthly script to check Contributions packages for Odyssey Core promotion eligibility",
  "bin": "./dist/cli.js",
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/atko-eng/odyssey-design-system",
    "directory": "packages/platform/odyssey-contributions-promotion-check"
  },
  "scripts": {
    "build:clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "yarn build:clean && tsc",
    "build:withDeps": "yarn workspaces foreach --from '@okta/odyssey-contributions-promotion-check' --recursive --topological run build",
    "build:watch": "yarn build:clean && tsc --watch",
    "test": "NODE_ENV=test vitest run --reporter=default",
    "check": "scripts/with-ui-stats.sh node dist/cli.js",
    "usage-detail": "scripts/with-ui-stats.sh node dist/cli-usage-detail.js"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.1.0",
    "memfs": "^4",
    "rimraf": "^6.0.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "typescript": "^5.8.3"
  }
}
