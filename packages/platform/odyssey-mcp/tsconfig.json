{
  "extends": "@okta/odyssey-typescript/tsconfig.node16.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "target": "es2024",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["vitest/globals"]
  },
  "include": ["*.ts", "src", "scripts"]
}
