{
  "name": "@okta/odyssey-mcp",
  "author": "Okta, Inc.",
  "license": "UNLICENSED",
  "version": "0.0.0-development",
  "description": "MCP server for the Odyssey design system",
  "bin": "./dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/atko-eng/odyssey-design-system",
    "directory": "packages/platform/odyssey-mcp"
  },
  "scripts": {
    "build:clean": "rimraf dist",
    "generate:components": "tsx scripts/generateMetadata.ts",
    "generate:tokens": "tsx scripts/generateTokens.ts",
    "generate:pictograms": "tsx scripts/generatePictograms.ts",
    "generate:contributions": "tsx scripts/generateContributions.ts",
    "generate:all-components": "tsx scripts/generateAllComponents.ts",
    "build": "yarn build:clean && yarn generate:components && yarn generate:tokens && yarn generate:pictograms && yarn generate:contributions && yarn generate:all-components && vite build",
    "build:deps": "yarn workspaces foreach --from '@okta/odyssey-mcp' --recursive --topological run build && yarn build",
    "build:watch": "yarn build:clean && vite build --watch",
    "inspect:build": "yarn build && yarn dlx @modelcontextprotocol/inspector node dist/index.js",
    "inspect": "yarn dlx @modelcontextprotocol/inspector node dist/index.js",
    "test": "NODE_ENV=test vitest run --reporter=default",
    "typecheck": "tsc --noEmit --rootDir ./"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@okta/odyssey-cli": "workspace:*",
    "fuse.js": "^7.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@okta/odyssey-design-tokens": "workspace:*",
    "@okta/odyssey-react-mui": "workspace:*",
    "@okta/odyssey-typescript": "workspace:*",
    "@types/node": "^20.0.0",
    "rimraf": "^6.0.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.7.3",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
